//@version=5
strategy("FX Hedge Scalper EA", 
         overlay=true, 
         initial_capital=10000, 
         default_qty_type=strategy.percent_of_equity, 
         default_qty_value=100,
         commission_type=strategy.commission.percent,
         commission_value=0.05,
         pyramiding=3)

//============================================================
// FX HEDGE SCALPER EA - TRADINGVIEW RECONSTRUCTION
// Top-2 EA 2026: Hedging + Scalping Strategy
// M1/M5 - Low Spread Requirement
//============================================================

// --- INPUTS ---
// Strategy
scalpTarget = input.float(8.0, "Scalp Target (pips)", step=0.5)
scalpSL     = input.float(15.0, "Scalp SL (pips)", step=0.5)
maxTrades   = input.int(3, "Max Trades/Direction")

// Hedging
useHedge    = input.bool(true, "Enable Hedging")
hedgeTrig   = input.float(20.0, "Hedge Trigger (pips loss)", step=1)
hedgeTP     = input.float(5.0, "Hedge TP (pips)", step=0.5)
hedgeSL     = input.float(40.0, "Hedge SL (pips)", step=1)

// Drawdown
useDDCtrl   = input.bool(true, "Smart Drawdown Control")
ddLevel1    = input.float(5.0, "DD Level 1 (%)", step=0.5)
ddLevel2    = input.float(10.0, "DD Level 2 (%)", step=0.5)
ddLevel3    = input.float(15.0, "DD Level 3 (%)", step=0.5)

// Risk
riskPct     = input.float(0.5, "Risk % per trade", step=0.1)

// Filters
maxSpread   = input.int(15, "Max Spread (points)")
minVolRatio = input.float(0.5, "Min Volume Ratio", step=0.1)

// --- INDICATORS ---
// Fast EMA 5
ema5 = ta.ema(close, 5)
ema21 = ta.ema(close, 21)
ema5_prev = ta.ema(close[1], 5)

// RSI (7)
rsi = ta.rsi(close, 7)

// Stochastic (5,3,3)
k = ta.sma(ta.stoch(close, high, low, 5), 3)
d = ta.sma(k, 3)

// MACD (12,26,9)
[macdLine, signalLine, histLine] = ta.macd(close, 12, 26, 9)

// Volume
volSMA = ta.sma(volume, 20)
volRatio = volume / volSMA

// Spread estimation (simplified)
spread = (high - low) * 0.15  // rough proxy

// --- DRAWDOWN CALC ---
peakEquity = ta.highest(strategy.equity, 100)
currentDD = (peakEquity - strategy.equity) / peakEquity * 100

// --- SCALP SIGNALS ---
pipSize = syminfo.mintick * 10

// BUY: EMA crossover + RSI oversold + MACD bullish + Stoch crossover + volume
buySignal = ta.crossover(ema5, ema21) and 
            rsi > 20 and rsi < 40 and 
            ta.crossover(macdLine, signalLine) and 
            ta.crossover(k, d) and k < 30 and
            volRatio >= minVolRatio

// SELL
sellSignal = ta.crossunder(ema5, ema21) and 
             rsi > 60 and rsi < 80 and 
             ta.crossunder(macdLine, signalLine) and 
             ta.crossunder(k, d) and k > 70 and
             volRatio >= minVolRatio

// --- LOT SIZE (DD-adjusted) ---
baseLot = (strategy.equity * riskPct / 100) / (scalpSL * pipSize * 10)
lotMultiplier = 1.0

if useDDCtrl
    if currentDD >= ddLevel2
        lotMultiplier := 0.5
    else if currentDD >= ddLevel1
        lotMultiplier := 0.8

adjustedLot = baseLot * lotMultiplier

// --- DAILY PROFIT TARGET ---
var float dailyPL = 0.0
var int lastTradeDay = dayofmonth
if dayofmonth != lastTradeDay
    dailyPL := 0.0
    lastTradeDay := dayofmonth

// Track daily P&L
if strategy.closedtrades > 0
    lastTradePL = strategy.closedtrades.profit(strategy.closedtrades - 1)
    // Add to daily if closed today
    dailyPL := dailyPL + 0  // simplified; PV tracking done via equity

// --- EXECUTION ---
// Normal trading
if buySignal and currentDD < ddLevel3 and spread <= maxSpread * syminfo.mintick
    if strategy.position_size >= 0  // not already short-heavy
        strategy.entry("SCALP L", strategy.long, qty=adjustedLot, comment="Scalp Buy")
        strategy.exit("XL L", "SCALP L", 
                      loss=scalpSL * pipSize / syminfo.mintick, 
                      profit=scalpTarget * pipSize / syminfo.mintick)

if sellSignal and currentDD < ddLevel3 and spread <= maxSpread * syminfo.mintick
    if strategy.position_size <= 0
        strategy.entry("SCALP S", strategy.short, qty=adjustedLot, comment="Scalp Sell")
        strategy.exit("XL S", "SCALP S",
                      loss=scalpSL * pipSize / syminfo.mintick, 
                      profit=scalpTarget * pipSize / syminfo.mintick)

// --- HEDGING (simplified in Pine) ---
// In Pine we can't truly hedge (netting system), so we simulate:
// When losing position exceeds hedgeTrigger, we close instead
if useHedge
    if strategy.openprofit < -(hedgeTrig * pipSize * 10 * adjustedLot)
        strategy.close_all(comment="Hedge Trigger Close")

// Smart DD Control: close all if DD exceeds max
if useDDCtrl and currentDD >= ddLevel3
    strategy.close_all(comment="DD Max - Close All")

// --- VISUALIZATION ---
// Plot EMAs
plot(ema5, "EMA 5", color=color.new(color.blue, 60), linewidth=2)
plot(ema21, "EMA 21", color=color.new(color.orange, 60), linewidth=1)

// Background - DD zones
bgcolor(useDDCtrl ? (currentDD >= ddLevel3 ? color.new(color.red, 80) : 
                     currentDD >= ddLevel2 ? color.new(color.orange, 85) :
                     currentDD >= ddLevel1 ? color.new(color.yellow, 90) : na) : na)

// Entry signals
plotshape(buySignal, "BUY", style=shape.triangleup, 
          color=color.new(color.green, 30), size=size.small, location=location.belowbar)
plotshape(sellSignal, "SELL", style=shape.triangledown, 
          color=color.new(color.red, 30), size=size.small, location=location.abovebar)

// --- INFO PANEL ---
var table info = table.new(position.top_right, 2, 8)
if barstate.islast
    ddColor = currentDD >= ddLevel3 ? color.red : 
              currentDD >= ddLevel2 ? color.orange :
              currentDD >= ddLevel1 ? color.yellow : color.green
    
    table.cell(info, 0, 0, "FX HEDGE SCALPER EA", text_color=color.white, bgcolor=color.new(color.navy, 40))
    table.cell(info, 0, 1, "DD:", text_color=color.gray)
    table.cell(info, 1, 1, str.tostring(currentDD, "#0.0") + "%", text_color=ddColor)
    table.cell(info, 0, 2, "Lot:", text_color=color.gray)
    table.cell(info, 1, 2, str.tostring(adjustedLot, "#0.000"), text_color=color.lime)
    table.cell(info, 0, 3, "Equity:", text_color=color.gray)
    table.cell(info, 1, 3, "$" + str.tostring(strategy.equity, "#,##0.00"), text_color=color.white)
    table.cell(info, 0, 4, "Open P/L:", text_color=color.gray)
    plColor = strategy.openprofit >= 0 ? color.green : color.red
    table.cell(info, 1, 4, "$" + str.tostring(strategy.openprofit, "#,##0.00"), text_color=plColor)
    table.cell(info, 0, 5, "RSI:", text_color=color.gray)
    table.cell(info, 1, 5, str.tostring(rsi, "#0.0"), text_color=rsi > 70 ? color.red : rsi < 30 ? color.green : color.white)
    table.cell(info, 0, 6, "Volume:", text_color=color.gray)
    table.cell(info, 1, 6, str.tostring(volRatio, "#0.0") + "x", text_color=volRatio >= minVolRatio ? color.green : color.red)
    table.cell(info, 0, 7, "Status:", text_color=color.gray)
    statusText = currentDD >= ddLevel3 ? "PAUSED ⛔" : currentDD >= ddLevel2 ? "REDUCE ⚠️" : "ACTIVE ✅"
    table.cell(info, 1, 7, statusText, text_color=ddColor)

// --- ALERTS ---
alertcondition(buySignal, "Hedge Scalper: BUY", "Hedge Scalper: BUY signal on {{ticker}}")
alertcondition(sellSignal, "Hedge Scalper: SELL", "Hedge Scalper: SELL signal on {{ticker}}")
