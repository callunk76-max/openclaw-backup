//@version=6
strategy(
  title="UFO Strategy Pro [Cuy]",
  shorttitle="UFO Pro",
  overlay=true,
  format=format.price,
  precision=2,
  initial_capital=10000,
  default_qty_type=strategy.percent_of_equity,
  default_qty_value=2,
  commission_type=strategy.commission.percent,
  commission_value=0.04
)

// ═══════════════════════════════════════════════════════════════════
// UFO STRATEGY PRO — Full Dwiyan Anggara Implementation
// ═══════════════════════════════════════════════════════════════════

// ── 1. SETTINGS ────────────────────────────────────────────────
// --- Core Zone ---
showDemand      = input.bool(true, "🟢 Demand Zone")
showSupply      = input.bool(true, "🔴 Supply Zone")
maxBaseCandles  = input.int(5, "Max Base Candle", 1, 10)
legMultiplier   = input.float(1.5, "Leg Out Multiplier", 1.0, 5.0, 0.1)
pivotStrength   = input.int(2, "Swing Strength", 1, 5)

// --- Trend & Filters ---
useDailyTrend   = input.bool(true, "🌊 Filter Daily Trend")
useEma9Filter   = input.bool(true, "🎯 Filter EMA 9 dlm Zone")
useSessionFilter = input.bool(false, "⏰ Filter Sesi Trading")
sessions        = input.string("London+NewYork", "Sesi Aktif",
                  options=["Asian", "London", "NewYork", "London+NewYork", "All"])
useNewsFilter   = input.bool(false, "📰 Filter High-Impact News")

// --- Unfilled Order (UFO Origin Detection) ---
useUFODetect    = input.bool(true, "🛸 Deteksi UFO Origin (Unfilled Order)")
ufoMoveMult     = input.float(2.0, "Min Move (xATR) utk UFO Origin", 1.0, 5.0, 0.1)
ufoVolRatio     = input.float(1.5, "Volume Ratio Threshold", 1.0, 5.0, 0.1)

// --- Scoring ---
useScoring      = input.bool(true, "📊 Scoring Detail")
minScore        = input.int(8, "Min Score (max 18)", 0, 18)

// --- Risk ---
rrRatio         = input.float(2.0, "Risk:Reward Ratio", 1.0, 10.0, 0.5)
useDynamicLot   = input.bool(true, "📏 Dynamic Lot by Zone Width")
riskPct         = input.float(2.0, "Risk % per Trade", 0.5, 5.0, 0.25)

// --- Visual ---
zoneExpiryBars  = input.int(50, "Zone Expiry (bars)", 10, 200)
showSaucerMarkers = input.bool(true, "🛸 Flying Saucer Markers")
showEma9        = input.bool(true, "📈 EMA 9")
showEma50       = input.bool(true, "📈 EMA 50")

// ── 2. INDICATORS ──────────────────────────────────────────────
atr14   = ta.atr(14)
ema9    = ta.ema(close, 9)
ema50   = ta.ema(close, 50)
avgVol  = ta.sma(volume, 14)
avgRange = ta.sma(high - low, 14)

plot(showEma9 ? ema9 : na, "EMA 9", #FF9800, 2)
plot(showEma50 ? ema50 : na, "EMA 50", #2196F3, 1)

// ── 3. DAILY TREND (MTF) ─────────────────────────────────────
dailyClose  = request.security(syminfo.tickerid, "D", close[1])
dailyEma50  = request.security(syminfo.tickerid, "D", ta.ema(close, 50)[1])
dailyTrend  = dailyClose > dailyEma50  // true = bullish
dailyAtr    = request.security(syminfo.tickerid, "D", ta.atr(14))

// ── 4. SESSION FILTER ─────────────────────────────────────────
isAsian   = hour(time('1D', '0000-0900')) >= 0 and hour(time) < 9
isLondon  = hour(time) >= 8 and hour(time) < 17
isNewYork = hour(time) >= 13 and hour(time) < 22

sessionOk = switch sessions
    "Asian"           => isAsian
    "London"          => isLondon
    "NewYork"         => isNewYork
    "London+NewYork"  => isLondon or isNewYork
    "All"             => true

// ── 5. NEWS FILTER (SIMPLIFIED) ───────────────────────────────
// Approximate major news times (NFP, FOMC, CPI etc — typically 8:30am NY / 2pm NY)
// User should enable/disable based on their own news calendar
isNewsTime = false  // placeholder — integrate with economic calendar if needed

// ── 6. UFO ORIGIN DETECTION (UNFILLED ORDER CORE CONCEPT) ────
// The key insight: when price moves FAST from a level with HIGH volume,
// it means NOT all orders were filled at that level.
// Those unfilled orders act as magnets — price will return.

var float[] ufoOrigins     = array.new<float>()    // price level of UFO origin
var float[] ufoStrength    = array.new<float>()    // strength (0-100) based on vol+range ratio
var int[]   ufoBarIdx      = array.new<int>()
var bool[]  ufoActive      = array.new<bool>()

// Detect UFO origin on every bar
candleRange  = high - low
rangeRatio   = candleRange / (avgRange > 0 ? avgRange : 1)
volRatio     = volume / (avgVol > 0 ? avgVol : 1)
moveATR      = math.abs(close - open) / (atr14 > 0 ? atr14 : 1)

isBigMove   = moveATR >= ufoMoveMult and rangeRatio >= ufoMoveMult * 0.8
isHighVol   = volRatio >= ufoVolRatio

if useUFODetect and isBigMove and isHighVol
    // Origin = the open/close of the previous candle (where the move started)
    originLevel = open  // the level from which price broke out
    ufoStr = math.min(100, (rangeRatio * 20) + (volRatio * 20) + (moveATR * 10))
    
    // Only store if not too close to existing UFO
    bool duplicate = false
    for j = 0 to array.size(ufoOrigins) - 1
        if math.abs(originLevel - array.get(ufoOrigins, j)) < atr14 * 0.3
            duplicate := true
    
    if not duplicate
        array.push(ufoOrigins,  originLevel)
        array.push(ufoStrength, ufoStr)
        array.push(ufoBarIdx,   bar_index)
        array.push(ufoActive,   true)

// ── 7. BASE PATTERN DETECTION (RBR / DBD / RBD / DBR) ────────
isBase    = candleRange < atr14 * 0.6 and volume < avgVol * 1.2

var int   baseCount    = 0
var float baseLowest   = na
var float baseHighest  = na
var int   baseStartIdx = 0
var float baseAvgVol   = 0.0
var float legInHigh    = na
var float legInLow     = na

var zoneProximal  = array.new<float>()
var zoneDistal    = array.new<float>()
var zoneIsDemand  = array.new<bool>()
var zonePattern   = array.new<string>()
var zoneBarIdx    = array.new<int>()
var zoneScore     = array.new<int>()
var zoneHasEma    = array.new<bool>()
var zoneActive    = array.new<bool>()
var zoneTouchCount = array.new<int>()   // freshness tracker
var zoneWidth     = array.new<float>()  // for dynamic lot sizing

// Running lookback (extracted for performance)
runHigh10 = ta.highest(high, 10)
runLow10  = ta.lowest(low, 10)

var int lastBuyBar  = 0
var int lastSellBar = 0

if isBase
    if baseCount == 0
        baseLowest   := low
        baseHighest  := high
        baseStartIdx := bar_index
        baseAvgVol   := volume
        legInHigh    := runHigh10
        legInLow     := runLow10
    else
        baseLowest   := math.min(baseLowest, low)
        baseHighest  := math.max(baseHighest, high)
        baseAvgVol   := (baseAvgVol * baseCount + volume) / (baseCount + 1)
    baseCount := baseCount + 1
else
    if baseCount >= 1 and baseCount <= maxBaseCandles
        baseRange   = baseHighest - baseLowest
        legOutRng   = high - low
        validBreak  = legOutRng >= baseRange * legMultiplier

        if validBreak
            rallyBefore = legInHigh > baseHighest
            dropBefore  = legInLow  < baseLowest
            rallyAfter  = high > baseHighest
            dropAfter   = low  < baseLowest

            isRBR = rallyBefore and rallyAfter
            isDBD = dropBefore  and dropAfter
            isRBD = rallyBefore and dropAfter
            isDBR = dropBefore  and rallyAfter

            // ── 8. DETAILED SCORING (max 18) ───────────────
            scoreA = 0  // Leg in quality (max 8)
            scoreB = 0  // Zone quality (max 10)

            if useScoring
                // A1: Leg in momentum (0-4)
                legInRange = math.abs(legInHigh - legInLow)
                if legInRange > atr14 * 1.5
                    scoreA := 4
                else if legInRange > atr14 * 0.8
                    scoreA := 2
                else
                    scoreA := 1

                // A2: Gap detection (0-2)
                gap = 0.0
                if isRBR or isRBD
                    gap := legInHigh - baseHighest
                else
                    gap := baseLowest - legInLow
                if gap > atr14 * 0.3
                    scoreA := scoreA + 2
                else if gap > 0
                    scoreA := scoreA + 1

                // A3: Volume confirmation (0-2)
                if baseAvgVol > avgVol * 1.3
                    scoreA := scoreA + 2
                else if baseAvgVol > avgVol
                    scoreA := scoreA + 1

                // B1: Leg out strength (0-4)
                legRatio = legOutRng / (baseRange > 0 ? baseRange : 1)
                if legRatio >= 3.0
                    scoreB := 4
                else if legRatio >= 2.0
                    scoreB := 3
                else if legRatio >= 1.5
                    scoreB := 2
                else
                    scoreB := 1

                // B2: Leg out volume (0-3)
                if volume > avgVol * 2.0
                    scoreB := scoreB + 3
                else if volume > avgVol * 1.5
                    scoreB := scoreB + 2
                else if volume > avgVol * 1.2
                    scoreB := scoreB + 1

                // B3: Base compactness (0-3)
                if baseCount == 1
                    scoreB := scoreB + 3
                else if baseCount <= 2
                    scoreB := scoreB + 2
                else if baseCount <= 4
                    scoreB := scoreB + 1

            totalScore = scoreA + scoreB

            // Filters
            emaInZone  = ema9 >= baseLowest and ema9 <= baseHighest
            trendBuy   = isRBR or isDBR
            trendSell  = isDBD or isRBD
            trendOk    = not useDailyTrend or (trendBuy and dailyTrend) or (trendSell and not dailyTrend)
            emaOk      = not useEma9Filter or emaInZone
            scoreOk    = not useScoring or totalScore >= minScore

            if trendOk and emaOk and scoreOk
                buf = atr14 * 0.1  // dynamic buffer based on ATR

                if (isRBR or isRBD) and showDemand
                    array.push(zoneProximal,  baseHighest + buf)
                    array.push(zoneDistal,    baseLowest  - buf)
                    array.push(zoneIsDemand,  true)
                    array.push(zonePattern,   isRBR ? "RBR" : "DBR")
                    array.push(zoneBarIdx,    bar_index)
                    array.push(zoneScore,     totalScore)
                    array.push(zoneHasEma,    emaInZone)
                    array.push(zoneActive,    true)
                    array.push(zoneTouchCount, 0)
                    array.push(zoneWidth,     baseRange)

                if (isDBD or isRBD) and showSupply
                    array.push(zoneProximal,  baseLowest  - buf)
                    array.push(zoneDistal,    baseHighest + buf)
                    array.push(zoneIsDemand,  false)
                    array.push(zonePattern,   isDBD ? "DBD" : "RBD")
                    array.push(zoneBarIdx,    bar_index)
                    array.push(zoneScore,     totalScore)
                    array.push(zoneHasEma,    emaInZone)
                    array.push(zoneActive,    true)
                    array.push(zoneTouchCount, 0)
                    array.push(zoneWidth,     baseRange)

    baseCount  := 0
    baseLowest := na
    baseHighest := na

// ── 9. ENTRY LOGIC ───────────────────────────────────────────
zoneCount = array.size(zoneProximal)
buySignal  = false
sellSignal = false
buySL = 0.0; buyTP = 0.0
sellSL = 0.0; sellTP = 0.0

if zoneCount > 0
    for i = 0 to zoneCount - 1
        if not array.get(zoneActive, i)
            continue

        age = bar_index - array.get(zoneBarIdx, i)
        if age > zoneExpiryBars
            array.set(zoneActive, i, false)
            continue

        zProx     = array.get(zoneProximal, i)
        zDist     = array.get(zoneDistal, i)
        isDem     = array.get(zoneIsDemand, i)
        zPattern  = array.get(zonePattern, i)
        zScore    = array.get(zoneScore, i)

        proxTop    = math.max(zProx, zDist)
        proxBottom = math.min(zProx, zDist)

        // Check if price enters zone
        inZone = low <= proxTop and high >= proxBottom
        priceInZone = close >= proxBottom and close <= proxTop

        // Track touches (freshness)
        if inZone
            tc = array.get(zoneTouchCount, i) + 1
            array.set(zoneTouchCount, i, tc)

        // Entry condition: price closes in zone
        if priceInZone
            // Session filter
            sessionOkForEntry = not useSessionFilter or sessionOk
            newsOk            = not useNewsFilter or not isNewsTime

            if isDem and sessionOkForEntry and newsOk
                buySignal := true
                zWidth = array.get(zoneWidth, i)
                buf = atr14 * 0.1
                buySL := zDist - buf
                riskPips = math.abs(close - buySL)
                buyTP := close + (riskPips * rrRatio)
                array.set(zoneActive, i, false)

            if not isDem and sessionOkForEntry and newsOk
                sellSignal := true
                zWidth = array.get(zoneWidth, i)
                buf = atr14 * 0.1
                sellSL := zDist + buf
                riskPips = math.abs(sellSL - close)
                sellTP := close - (riskPips * rrRatio)
                array.set(zoneActive, i, false)

// ── 10. EXECUTE TRADES ───────────────────────────────────────
noRecentBuy  = bar_index - lastBuyBar  > 3
noRecentSell = bar_index - lastSellBar > 3

qtyCalc = strategy.default_qty_value
if useDynamicLot and array.size(zoneWidth) > 0
    // Dynamic position sizing based on risk per trade
    avgWidth = ta.sma(atr14, 14)
    if avgWidth > 0
        riskEq = strategy.equity * riskPct / 100
        slPts  = buySL > 0 ? math.abs(close - buySL) / syminfo.mintick : atr14 / syminfo.mintick
        if slPts > 0
            qtyCalc := math.floor(riskEq / (slPts * syminfo.mintick * 100000))

if buySignal and noRecentBuy and strategy.position_size == 0
    strategy.entry("UFO Buy", strategy.long, qty=qtyCalc)
    strategy.exit("UFO Buy Exit", "UFO Buy",
                  stop=buySL, limit=buyTP,
                  comment="🛸 UFO BUY")
    lastBuyBar := bar_index

if sellSignal and noRecentSell and strategy.position_size == 0
    strategy.entry("UFO Sell", strategy.short, qty=qtyCalc)
    strategy.exit("UFO Sell Exit", "UFO Sell",
                  stop=sellSL, limit=sellTP,
                  comment="🛸 UFO SELL")
    lastSellBar := bar_index

// ── 11. RENDER ZONES ─────────────────────────────────────────
if barstate.islast
    // Clear old flying saucers
    if showSaucerMarkers
        for i = 0 to 200
            label.delete(labelBase + "_Saucer_" + str.tostring(i))

    for i = 0 to zoneCount - 1
        if not array.get(zoneActive, i)
            continue
        age = bar_index - array.get(zoneBarIdx, i)
        if age > zoneExpiryBars
            continue

        zProx  = array.get(zoneProximal, i)
        zDist  = array.get(zoneDistal, i)
        isDem  = array.get(zoneIsDemand, i)
        pat    = array.get(zonePattern, i)
        score  = array.get(zoneScore, i)
        zEma   = array.get(zoneHasEma, i)
        zTouch = array.get(zoneTouchCount, i)

        // Opacity: base on age + freshness
        ageAlpha = math.max(20, 85 - int(age * 65 / math.max(zoneExpiryBars, 1)))
        touchPenalty = zTouch * 10
        alphaVal = math.max(15, ageAlpha - touchPenalty)

        // Strength gradient: higher score = more vibrant
        intensity = math.min(1.0, score / 18.0)
        col = isDem
            ? color.new(color.green, 100 - int(alphaVal * intensity))
            : color.new(color.red,   100 - int(alphaVal * intensity))
        colBorder = isDem
            ? color.new(#00E676, 100 - math.min(alphaVal + 10, 100))
            : color.new(#FF5252, 100 - math.min(alphaVal + 10, 100))

        topL = math.max(zProx, zDist)
        botL = math.min(zProx, zDist)

        // Zone lines
        line.new(array.get(zoneBarIdx, i), zProx, bar_index, zProx, color=colBorder, width=1)
        line.new(array.get(zoneBarIdx, i), zDist, bar_index, zDist,
                 color=color.new(color.gray, 100 - alphaVal), width=1, style=line.style_dashed)

        // Label
        labelTxt = pat + " S:" + str.tostring(score)
        if zEma
            labelTxt += "✓"
        if zTouch > 0
            labelTxt += " x" + str.tostring(zTouch)
        label.new(array.get(zoneBarIdx, i), isDem ? zProx : zDist, labelTxt,
                  color=col, textcolor=color.white,
                  style=isDem ? label.style_label_down : label.style_label_up,
                  size=size.small)

    // ── FLYING SAUCER MARKERS ─────────────────────────────
    if showSaucerMarkers
        ufoCount = array.size(ufoOrigins)
        for i = 0 to ufoCount - 1
            if not array.get(ufoActive, i)
                continue
            age = bar_index - array.get(ufoBarIdx, i)
            if age > zoneExpiryBars
                continue

            level   = array.get(ufoOrigins, i)
            str     = array.get(ufoStrength, i)
            alpha   = math.max(20, 80 - int(age * 60 / zoneExpiryBars))

            // Circle marker ○ using label with circle symbol
            ufoChar = str >= 70 ? "🛸" : str >= 40 ? "○" : "·"
            ufoCol  = str >= 70 ? color.new(#FF6D00, 100 - alpha) :
                      str >= 40 ? color.new(#FFB300, 100 - alpha) :
                                  color.new(#9E9E9E, 100 - alpha)

            label.new(array.get(ufoBarIdx, i), level, ufoChar,
                      color=color.new(#1a1a2e, 90),
                      textcolor=ufoCol,
                      style=label.style_none,
                      size=str >= 70 ? size.large : size.normal)

// ── 12. UFO ORIGIN RE-ENTRY SIGNAL ──────────────────────────
// Price returning to UFO origin level = high probability bounce
var bool ufoReentrySignal = false
var string ufoReentrySide = ""

if useUFODetect
    for i = 0 to array.size(ufoOrigins) - 1
        if not array.get(ufoActive, i)
            continue
        level = array.get(ufoOrigins, i)
        str   = array.get(ufoStrength, i)
        distPct = math.abs(close - level) / (atr14 > 0 ? atr14 : 1)

        // Price returned to within 0.5 ATR of origin level
        if distPct < 0.5 and str >= 40
            // Determine direction based on where the original move went
            // If origin is above current price → price is below origin → potential bounce up
            if close < level
                ufoReentrySignal := true
                ufoReentrySide := "BUY"
            else
                ufoReentrySignal := true
                ufoReentrySide := "SELL"
            array.set(ufoActive, i, false)

// ── 13. TABLE ───────────────────────────────────────────────
var table info = table.new(position.top_right, 1, 1,
                            bgcolor=color.new(#0D0D1A, 95),
                            border_color=color.new(#555555, 60))

if barstate.islast
    // Session indicator
    sessionStr = isAsian ? "🇯🇵 Asian" : isLondon ? "🇬🇧 London" : isNewYork ? "🇺🇸 NY" : "🌙 Off"

    posText  = "🛸 UFO PRO STRATEGY\n"
    posText += "══════════════════\n"
    posText += "⏰ " + sessionStr + "\n"
    posText += "📊 Equity: $" + str.tostring(math.round(strategy.equity, 0)) + "\n"
    posText += "📈 Open: " + (strategy.position_size > 0 ? "🟢 LONG" : strategy.position_size < 0 ? "🔴 SHORT" : "⚪ NONE") + "\n"
    posText += "🌊 Trend: " + (dailyTrend ? "🟢 Bull" : "🔴 Bear") + "\n"
    posText += "──────────────\n"
    posText += "🏗 Zones: " + str.tostring(zoneCount) + "\n"
    posText += "🛸 UFOs: " + str.tostring(array.size(ufoOrigins)) + "\n"
    posText += "🎯 Score: min " + str.tostring(minScore) + "/18\n"
    posText += "⚙ RR: 1:" + str.tostring(rrRatio) + "\n"
    if ufoReentrySignal
        posText += "\n💥 UFO Re-entry: " + ufoReentrySide

    table.cell(info, 0, 0, posText, text_color=#AAAAAA, text_size=size.small)

// ── 14. ALERTS ──────────────────────────────────────────────
alertcondition(buySignal,  "UFO Buy Signal",  "🛸 UFO PRO: BUY signal detected")
alertcondition(sellSignal, "UFO Sell Signal", "🛸 UFO PRO: SELL signal detected")
alertcondition(ufoReentrySignal, "UFO Re-entry Signal",
               "🛸 UFO PRO: Re-entry at origin level — " + ufoReentrySide)
