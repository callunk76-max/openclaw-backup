//@version=5
indicator(title="DA Trading Assistant", overlay=true, max_labels_count=500)

// === INPUTS ===
riskPct  = input.float(2.0,   "Risk % per Trade", minval=0.1, maxval=100.0)
balance  = input.float(10000, "Account Balance ($)", minval=100.0)
slPips   = input.float(100.0, "Default SL (pips)", minval=10.0)
rrMin    = input.float(1.5,   "Min Risk/Reward", minval=1.0)
useAtr   = input.bool(true,   "Use ATR for SL")
atrMlt   = input.float(1.5,   "ATR Multiplier", minval=0.5)
atrLen   = input.int(14,      "ATR Period", minval=7, maxval=50)
showRSW  = input.bool(true,   "Show RSW")
rswLen   = input.int(20,      "RSW Period", minval=5, maxval=100)
showPnl  = input.bool(true,   "Show Panel")
showSig  = input.bool(true,   "Show Signals")
showFib  = input.bool(true,   "Show Fibonacci")

// === CALCULATIONS ===
myAtr   = ta.atr(atrLen)
slDist  = useAtr ? myAtr * atrMlt : slPips * syminfo.mintick * 10
riskAmt = balance * riskPct / 100.0
lotVal  = riskAmt / (slDist / syminfo.mintick / 10)

rrA = rrMin
rrB = rrMin * 2.0
rrC = rrMin * 3.0

// Prices
slBuy  = close - slDist
slSell = close + slDist
tpBuy1 = close + slDist * rrA
tpBuy2 = close + slDist * rrB
tpBuy3 = close + slDist * rrC
tpSell1 = close - slDist * rrA
tpSell2 = close - slDist * rrB
tpSell3 = close - slDist * rrC

// === RSW ===
rswVal  = (close - close[rswLen]) / close[rswLen] * 100
rswMa   = ta.sma(rswVal, rswLen)
rswSd   = ta.stdev(rswVal, rswLen) * 1.5
rswTop  = rswMa + rswSd
rswBot  = rswMa - rswSd
rswBull = rswVal > rswTop
rswBear = rswVal < rswBot

// === SIGNALS ===
e9  = ta.ema(close, 9)
e21 = ta.ema(close, 21)
e50 = ta.ema(close, 50)

trendUp   = e9 > e21 and e21 > e50
trendDown = e9 < e21 and e21 < e50

vRatio = volume / ta.sma(volume, 20)
candleUp = close > open
candleDn = close < open

sigBuy  = ta.crossunder(close, e21) and trendUp and candleUp
sigSell = ta.crossover(close, e21) and trendDown and candleDn
sigBkUp = ta.crossover(close, e50) and trendUp and vRatio > 1.2
sigBkDn = ta.crossunder(close, e50) and trendDown and vRatio > 1.2

// === PLOTS ===
// NOTE: all plot() must be at global scope in v5

// EMAs
plot(e9,  "EMA9",  color=color.new(color.blue,   70), linewidth=1)
plot(e21, "EMA21", color=color.new(color.orange, 70), linewidth=2)
plot(e50, "EMA50", color=color.new(color.purple, 70), linewidth=1)

// Entries
plotshape(series=showSig and sigBuy,  title="Buy",  style=shape.triangleup,   location=location.belowbar, color=color.new(color.green,40), size=size.tiny)
plotshape(series=showSig and sigBkUp, title="BkUp", style=shape.labelup,      location=location.belowbar, color=color.new(color.lime,50),  size=size.tiny)
plotshape(series=showSig and sigSell, title="Sell", style=shape.triangledown, location=location.abovebar, color=color.new(color.red,40),   size=size.tiny)
plotshape(series=showSig and sigBkDn, title="BkDn", style=shape.labeldown,    location=location.abovebar, color=color.new(color.maroon,50),size=size.tiny)

// RSW
rswCol = rswBull ? color.green : rswBear ? color.red : color.gray
plot(series=showRSW ? rswVal : na, title="RSW",    color=rswCol,           linewidth=2)
plot(series=showRSW ? rswMa  : na, title="RSW MA", color=color.yellow,     linewidth=1)
plot(series=showRSW ? rswTop : na, title="RSW Top", color=color.new(color.green,60), linewidth=1)
plot(series=showRSW ? rswBot : na, title="RSW Bot", color=color.new(color.red,60),   linewidth=1)
hline(price=0, title="Zero", color=color.new(color.gray,50), linestyle=hline.style_solid)

// === LABELS ===
if showSig and sigBuy
    label.new(x=bar_index, y=low, text="▲ BUY Lot:" + str.tostring(lotVal,"0.00") +
      "\nSL:" + str.tostring(slBuy,"0.00000") + "\nTP:" + str.tostring(tpBuy1,"0.00000"),
      style=label.style_label_up, color=color.new(color.green,60), textcolor=color.white, size=size.tiny)

if showSig and sigSell
    label.new(x=bar_index, y=high, text="▼ SELL Lot:" + str.tostring(lotVal,"0.00") +
      "\nSL:" + str.tostring(slSell,"0.00000") + "\nTP:" + str.tostring(tpSell1,"0.00000"),
      style=label.style_label_down, color=color.new(color.red,60), textcolor=color.white, size=size.tiny)

// === LINES (last bar) ===
if barstate.islast
    line.new(x1=bar_index, y1=slBuy,  x2=bar_index+5, y2=slBuy,  color=color.red,   width=1)
    line.new(x1=bar_index, y1=slSell, x2=bar_index+5, y2=slSell, color=color.red,   width=1)
    line.new(x1=bar_index, y1=tpBuy1, x2=bar_index+5, y2=tpBuy1, color=color.green, width=1)
    line.new(x1=bar_index, y1=tpSell1,x2=bar_index+5, y2=tpSell1,color=color.green, width=1)

// === FIBONACCI ===
var line f238 = line.new(na,na,na,na)
var line f382 = line.new(na,na,na,na)
var line f500 = line.new(na,na,na,na)
var line f618 = line.new(na,na,na,na)
var line f786 = line.new(na,na,na,na)

fHi = ta.highest(high, 50)
fLo = ta.lowest(low, 50)
fR  = fHi - fLo

if showFib and barstate.islast and fR > 0
    line.set_xy1(f238, bar_index-50, fHi - fR*0.236)
    line.set_xy2(f238, bar_index,    fHi - fR*0.236)
    line.set_color(f238, color.new(color.gray,50))
    line.set_style(f238, line.style_dotted)

    line.set_xy1(f382, bar_index-50, fHi - fR*0.382)
    line.set_xy2(f382, bar_index,    fHi - fR*0.382)
    line.set_color(f382, color.new(color.blue,60))
    line.set_style(f382, line.style_dashed)

    line.set_xy1(f500, bar_index-50, fHi - fR*0.5)
    line.set_xy2(f500, bar_index,    fHi - fR*0.5)
    line.set_color(f500, color.new(color.orange,70))
    line.set_style(f500, line.style_solid)

    line.set_xy1(f618, bar_index-50, fHi - fR*0.618)
    line.set_xy2(f618, bar_index,    fHi - fR*0.618)
    line.set_color(f618, color.new(color.red,70))
    line.set_style(f618, line.style_dashed)

    line.set_xy1(f786, bar_index-50, fHi - fR*0.786)
    line.set_xy2(f786, bar_index,    fHi - fR*0.786)
    line.set_color(f786, color.new(color.purple,50))
    line.set_style(f786, line.style_dotted)

// === PANEL ===
if showPnl
    var tbl = table.new(position.top_right, 2, 9, frame_color=color.new(color.blue,70))
    if barstate.islast
        table.cell(tbl, 0, 0, "DA ASSISTANT", text_color=color.white, bgcolor=color.new(color.navy,50))
        table.cell(tbl, 0, 1, "Balance", text_color=color.gray)
        table.cell(tbl, 1, 1, "$"+str.tostring(balance,"#,##0"), text_color=color.white)
        table.cell(tbl, 0, 2, "Risk", text_color=color.gray)
        table.cell(tbl, 1, 2, str.tostring(riskPct,"0.0")+"%", text_color=color.yellow)
        table.cell(tbl, 0, 3, "Lot", text_color=color.gray)
        table.cell(tbl, 1, 3, str.tostring(lotVal,"0.00"), text_color=color.lime)
        table.cell(tbl, 0, 4, "SL", text_color=color.gray)
        table.cell(tbl, 1, 4, str.tostring(slDist/syminfo.mintick,"0")+" pts", text_color=color.red)
        table.cell(tbl, 0, 5, "RR", text_color=color.gray)
        table.cell(tbl, 1, 5, "1:"+str.tostring(rrA,"0.0"), text_color=color.orange)
        table.cell(tbl, 0, 6, "RSW", text_color=color.gray)
        table.cell(tbl, 1, 6, rswBull?"BULL":rswBear?"BEAR":"--", text_color=rswCol)
        table.cell(tbl, 0, 7, "ATR", text_color=color.gray)
        table.cell(tbl, 1, 7, str.tostring(myAtr/syminfo.mintick,"0.0")+" pts", text_color=color.aqua)
        table.cell(tbl, 0, 8, "Trend", text_color=color.gray)
        table.cell(tbl, 1, 8, trendUp?"BULL ▲":trendDown?"BEAR ▼":"--", text_color=trendUp?color.green:trendDown?color.red:color.gray)

// === ALERTS ===
alertcondition(condition=sigBuy,  title="Buy Signal",  message="DA: BUY {{ticker}}")
alertcondition(condition=sigSell, title="Sell Signal", message="DA: SELL {{ticker}}")
alertcondition(condition=sigBkUp, title="BkUp Signal", message="DA: Breakout UP {{ticker}}")
alertcondition(condition=sigBkDn, title="BkDn Signal", message="DA: Breakout DOWN {{ticker}}")
