//@version=5
indicator("CuyPro New SC-Giraia V4", overlay=true)

// ==========================================
// SETTINGS (Giraia Style)
// ==========================================
lookback = input.int(1, "Lookback Period", minval=1)
show_dashboard = input.bool(true, "Tampilkan Dashboard")
text_size = input.string("Small", "Ukuran Teks", options=["Tiny", "Small", "Normal", "Large"])

// Threshold Colors based on Accumulative Score
// Since we sum 7 pairs, max score is 63, min is 0.
// Strong: approx 7.0 avg * 7 = 49 | Weak: approx 2.0 avg * 7 = 14
color_strong = input.color(color.new(color.green, 40), "Strong Color (>= 49)")
color_weak = input.color(color.new(color.red, 40), "Weak Color (<= 14)")
color_neutral = input.color(color.new(color.white, 40), "Neutral Color")

// Konversi ukuran teks
size_map = text_size == "Tiny" ? size.tiny : text_size == "Small" ? size.small : text_size == "Normal" ? size.normal : size.large

// ==========================================
// GIRAIA LOGIC: CURRENCY STRENGTH CALCULATION
// ==========================================
get_strength_val(sym) =>
    float day_high = request.security(sym, "D", high[1])
    float day_low  = request.security(sym, "D", low[1])
    float curr_bid = request.security(sym, timeframe.period, close)
    
    float bid_ratio = (day_high - day_low == 0) ? 0 : (curr_bid - day_low) / (day_high - day_low)
    
    int strength = 0
    if bid_ratio >= 0.97
        strength := 9
    else if bid_ratio >= 0.90
        strength := 8
    else if bid_ratio >= 0.75
        strength := 7
    else if bid_ratio >= 0.60
        strength := 6
    else if bid_ratio >= 0.50
        strength := 5
    else if bid_ratio >= 0.40
        strength := 4
    else if bid_ratio >= 0.25
        strength := 3
    else if bid_ratio >= 0.10
        strength := 2
    else if bid_ratio >= 0.03
        strength := 1
    else
        strength := 0
    strength

// ==========================================
// ACCUMULATIVE STRENGTH (Pure Summation from callunk.mq4)
// ==========================================
// Calculation: Base gets strength, Quote gets (9 - strength)

// USD: EURUSD, GBPUSD, AUDUSD, NZDUSD, USDCAD, USDCHF, USDJPY
float usd_total = (9 - get_strength_val("EURUSD")) + (9 - get_strength_val("GBPUSD")) + (9 - get_strength_val("AUDUSD")) + (9 - get_strength_val("NZDUSD")) + get_strength_val("USDCAD") + get_strength_val("USDCHF") + get_strength_val("USDJPY")

// EUR: EURUSD, EURGBP, EURJPY, EURCAD, EURCHF, EURAUD, EURNZD
float eur_total = get_strength_val("EURUSD") + (9 - get_strength_val("EURGBP")) + get_strength_val("EURJPY") + get_strength_val("EURCAD") + get_strength_val("EURCHF") + get_strength_val("EURAUD") + get_strength_val("EURNZD")

// GBP: GBPUSD, EURGBP, GBPJPY, GBPCAD, GBPCHF, GBPAUD, GBPNZD
float gbp_total = get_strength_val("GBPUSD") + get_strength_val("EURGBP") + get_strength_val("GBPJPY") + get_strength_val("GBPCAD") + get_strength_val("GBPCHF") + get_strength_val("GBPAUD") + get_strength_val("GBPNZD")
// Correction for EURGBP: if EUR is base, GBP is quote.
float gbp_sum = get_strength_val("GBPUSD") + (9 - get_strength_val("EURGBP")) + get_strength_val("GBPJPY") + get_strength_val("GBPCAD") + get_strength_val("GBPCHF") + get_strength_val("GBPAUD") + get_strength_val("GBPNZD")

// JPY: USDJPY, EURJPY, GBPJPY, AUDJPY, NZDJPY, CADJPY, CHFJPY
float jpy_total = (9 - get_//strength_val("USDJPY")) + (9 - get_strength_val("EURJPY")) + (9 - get_strength_val("GBPJPY")) + (9 - get_strength_val("AUDJPY")) + (9 - get_strength_val("NZDJPY")) + (9 - get_strength_val("CADJPY")) + (9 - get_strength_val("CHFJPY"))

// AUD: AUDUSD, EURAUD, GBPAUD, AUDJPY, AUDCAD, AUDCHF, AUDNZD
float aud_total = get_strength_val("AUDUSD") + (9 - get_strength_val("EURAUD")) + (9 - get_strength_val("GBPAUD")) + get_strength_val("AUDJPY") + get_strength_val("AUDCAD") + get_strength_val("AUDCHF") + get_strength_val("AUDNZD")

// NZD: NZDUSD, EURNZD, GBPNZD, NZDJPY, NZDCAD, NZDCHF, AUDNZD
float nzd_total = get_strength_val("NZDUSD") + (9 - get_strength_val("EURNZD")) + (9 - get_strength_val("GBPNZD")) + get_strength_val("NZDJPY") + get_strength_val("NZDCAD") + get_strength_val("NZDCHF") + (9 - get_strength_val("AUDNZD"))

// CAD: USDCAD, EURCAD, GBPCAD, CADJPY, AUDCAD, NZDCAD, CADCHF
float cad_total = (9 - get_strength_val("USDCAD")) + (9 - get_strength_val("EURCAD")) + (9 - get_strength_val("GBPCAD")) + get_strength_val("CADJPY") + (9 - get_strength_val("AUDCAD")) + (9 - get_strength_val("NZDCAD")) + (9 - get_strength_val("CADCHF"))

// CHF: USDCHF, EURCHF, GBPCHF, CHFJPY, AUDCHF, NZDCHF, CADCHF
float chf_total = (9 - get_strength_val("USDCHF")) + (9 - get_strength_val("EURCHF")) + (9 - get_strength_val("GBPCHF")) + get_strength_val("CHFJPY") + (9 - get_strength_val("AUDCHF")) + (9 - get_strength_val("NZDCHF")) + (9 - get_strength_val("CADCHF"))

// ==========================================
// SORTING & DASHBOARD
// ==========================================
var float[] strengths = array.new_float(0)
var string[] names = array.new_string(0)

if barstate.islast
    array.clear(strengths)
    array.clear(names)
    array.push(strengths, usd_total), array.push(names, "USD")
    array.push(strengths, eur_total), array.push(names, "EUR")
    array.push(strengths, gbp_sum), array.push(names, "GBP")
    array.push(strengths, jpy_total), array.push(names, "JPY")
    array.push(strengths, aud_total), array.push(names, "AUD")
    array.push(strengths, nzd_total), array.push(names, "NZD")
    array.push(strengths, cad_total), array.push(names, "CAD")
    array.push(strengths, chf_total), array.push(names, "CHF")

    for i = 0 to array.size(strengths) - 2
        for j = i + 1 to array.size(strengths) - 1
            if array.get(strengths, i) < array.get(strengths, j)
                float t_s = array.get(strengths, i)
                string t_n = array.get(names, i)
                array.set(strengths, i, array.get(strengths, j))
                array.set(names, i, array.get(names, j))
                array.set(strengths, j, t_s)
                array.set(names, j, t_n)

if show_dashboard and barstate.islast
    var table st = table.new(position.top_right, 2, 9, bgcolor=color.new(color.black, 30), border_width=1, border_color=color.gray)
    table.cell(st, 0, 0, "Currency", text_color=color.white, bgcolor=color.rgb(60, 60, 60), text_size=size_map)
    table.cell(st, 1, 0, "Power", text_color=color.white, bgcolor=color.rgb(60, 60, 60), text_size=size_map)
    
    for i = 0 to array.size(strengths) - 1
        float val = array.get(strengths, i)
        string name = array.get(names, i)
        color c = val >= 49.0 ? color_strong : val <= 14.0 ? color_weak : color_neutral
        table.cell(st, 0, i + 1, name, text_color=color.white, bgcolor=c, text_size=size_map)
        table.cell(st, 1, i + 1, str.tostring(val, "#.##"), text_color=color.white, bgcolor=c, text_size=size_map)
